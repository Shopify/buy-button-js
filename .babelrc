{
  "presets": [
    ["@babel/preset-typescript", {
      "isTSX": false,
      "allExtensions": true
    }]
  ],
  "env": {
    "development": {
      // Retained for Browserify/testem test pipeline — removed in PR 7a when Vitest replaces Browserify
      "plugins": [
        "@babel/plugin-transform-modules-commonjs"
      ]
    }
  }
}
